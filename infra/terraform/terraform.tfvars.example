# Copy to terraform.tfvars (gitignored) and fill in.
#
# All values here have sensible defaults in variables.tf; the tfvars
# file is where you override per-deploy knobs like image_tag and
# desired_count without editing the HCL.

# Image tag whose digest the task definition pins to. Routine deploys
# overwrite this tag in ECR via `docker push :latest` and the next
# `terraform apply` reads the new digest and rolls. The task definition
# references the immutable digest, not the tag, so deploy circuit-breaker
# rollback works as intended.
image_tag = "latest"

# Number of running Fargate tasks. Bump and `terraform apply` to scale.
desired_count = 1

# Keep this false until the new stack is up and /health returns 200
# on the new ALB's DNS name directly. Flipping to true cuts production
# DNS over to the new ALB.
create_cutover_dns = false

# Uncomment to override defaults:
# task_cpu           = 1024
# task_memory        = 2048
# waf_rate_limit     = 20000
# log_retention_days = 14
