{
  "name": "@keypears/client",
  "version": "1.0.0",
  "description": "Typed KeyPears client and auth helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "default": "./dist/contract.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/keypears/keypears.git",
    "directory": "packages/client"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@orpc/client": "^1.14.0",
    "@orpc/contract": "^1.14.0",
    "@webbuf/fixedbuf": "^3.8.0",
    "@webbuf/sig-ed25519-mldsa": "^3.8.0",
    "@webbuf/webbuf": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
