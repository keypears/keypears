{
  "name": "keypears",
  "type": "module",
  "scripts": {
    "dev": "dotenvx run -f .env.dev -- vite",
    "build": "vite build",
    "start": "bun dist/server/server.js",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "dotenvx run -f .env.dev -- drizzle-kit push",
    "db:generate": "dotenvx run -f .env.dev -- drizzle-kit generate",
    "build:icons": "bun run process-icons.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-start": "^1.163.3",
    "@webbuf/acs2": "^3.5.0",
    "@webbuf/fixedbuf": "^3.5.0",
    "@webbuf/secp256k1": "^3.5.0",
    "@webbuf/sha256": "^3.5.0",
    "@webbuf/webbuf": "^3.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "mysql2": "^3.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
