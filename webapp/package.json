{
  "name": "@keypears/webapp",
  "type": "module",
  "scripts": {
    "dev:keypears": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.dev -- vite --port 3500",
    "dev:passapples": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.dev.passapples -- vite --port 3512",
    "dev:e2e:keypears": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.e2e -- vite --host 127.0.0.1 --port 3500",
    "dev:e2e:passapples": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.e2e.passapples -- vite --host 127.0.0.1 --port 3512",
    "dev:e2e:passapples-site": "cd ../passapples && bunx astro dev --host 127.0.0.1 --port 3510",
    "dev:e2e:lockberries-site": "cd ../lockberries && bunx astro dev --host 127.0.0.1 --port 3520",
    "build": "bun run build:blog && vite build",
    "build:blog": "bun build-blog.ts",
    "start": "bun dist/server/server.js",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "bun run db:push:keypears && bun run db:push:passapples",
    "db:push:keypears": "dotenvx run -f .env.dev -- drizzle-kit push",
    "db:push:passapples": "dotenvx run -f .env.dev.passapples -- drizzle-kit push",
    "db:push:prod": "dotenvx run -f .env.prod -- drizzle-kit push",
    "db:clear": "bun run db:clear:keypears && bun run db:clear:passapples",
    "db:clear:keypears": "dotenvx run -f .env.dev -- drizzle-kit push --config drizzle.clear.config.ts",
    "db:clear:passapples": "dotenvx run -f .env.dev.passapples -- drizzle-kit push --config drizzle.clear.config.ts",
    "db:clear:prod": "dotenvx run -f .env.prod -- drizzle-kit push --config drizzle.clear.config.ts",
    "db:create:e2e:keypears": "dotenvx run -f .env.e2e -- bun scripts/create-e2e-db.ts",
    "db:create:e2e:passapples": "dotenvx run -f .env.e2e.passapples -- bun scripts/create-e2e-db.ts",
    "db:create:e2e": "bun run db:create:e2e:keypears && bun run db:create:e2e:passapples",
    "db:clear:e2e:keypears": "dotenvx run -f .env.e2e -- drizzle-kit push --config drizzle.clear.config.ts --force",
    "db:clear:e2e:passapples": "dotenvx run -f .env.e2e.passapples -- drizzle-kit push --config drizzle.clear.config.ts --force",
    "db:clear:e2e": "bun run db:clear:e2e:keypears && bun run db:clear:e2e:passapples",
    "db:push:e2e:keypears": "dotenvx run -f .env.e2e -- drizzle-kit push",
    "db:push:e2e:passapples": "dotenvx run -f .env.e2e.passapples -- drizzle-kit push",
    "db:push:e2e": "bun run db:push:e2e:keypears && bun run db:push:e2e:passapples",
    "db:reset:e2e": "bun run db:create:e2e && bun run db:clear:e2e && bun run db:push:e2e",
    "db:generate": "dotenvx run -f .env.dev -- drizzle-kit generate",
    "build:icons": "bun run process-icons.ts",
    "test": "dotenvx run -f .env.test -- vitest run",
    "e2e": "bun run db:reset:e2e && playwright test"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.63.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@keypears/client": "workspace:*",
    "@keypears/pow5": "workspace:*",
    "@orpc/client": "^1.14.0",
    "@orpc/contract": "^1.14.0",
    "@orpc/server": "^1.14.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-start": "^1.167.49",
    "@webbuf/aesgcm": "^3.8.0",
    "@webbuf/aesgcm-x25519dh-mlkem": "^3.8.0",
    "@webbuf/ed25519": "^3.8.0",
    "@webbuf/fixedbuf": "^3.8.0",
    "@webbuf/mldsa": "^3.8.0",
    "@webbuf/mlkem": "^3.8.0",
    "@webbuf/pbkdf2-sha256": "^3.8.0",
    "@webbuf/sha256": "^3.8.0",
    "@webbuf/sig-ed25519-mldsa": "^3.8.0",
    "@webbuf/webbuf": "^3.8.0",
    "@webbuf/x25519": "^3.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "feed": "^5.2.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.11.0",
    "mysql2": "^3.22.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "toml": "^4.1.1",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@webgpu/types": "^0.1.69",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
