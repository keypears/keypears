{
  "name": "@keypears/webapp",
  "type": "module",
  "scripts": {
    "dev:keypears": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.dev -- vite --port 3500",
    "dev:passapples": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.dev.passapples -- vite --port 3512",
    "build": "bun run build:blog && vite build",
    "build:blog": "bun build-blog.ts",
    "start": "bun dist/server/server.js",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "bun run db:push:keypears && bun run db:push:passapples",
    "db:push:keypears": "dotenvx run -f .env.dev -- drizzle-kit push",
    "db:push:passapples": "dotenvx run -f .env.dev.passapples -- drizzle-kit push",
    "db:push:prod": "dotenvx run -f .env.prod -- drizzle-kit push",
    "db:clear": "bun run db:clear:keypears && bun run db:clear:passapples",
    "db:clear:keypears": "dotenvx run -f .env.dev -- drizzle-kit push --config drizzle.clear.config.ts",
    "db:clear:passapples": "dotenvx run -f .env.dev.passapples -- drizzle-kit push --config drizzle.clear.config.ts",
    "db:generate": "dotenvx run -f .env.dev -- drizzle-kit generate",
    "build:icons": "bun run process-icons.ts",
    "test": "dotenvx run -f .env.test -- vitest run",
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.61.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@keypears/pow5": "workspace:*",
    "@orpc/client": "^1.13.14",
    "@orpc/server": "^1.13.14",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/react-start": "^1.167.32",
    "@webbuf/aesgcm": "^3.5.0",
    "@webbuf/fixedbuf": "^3.5.0",
    "@webbuf/p256": "^3.5.1",
    "@webbuf/pbkdf2-sha256": "^3.5.1",
    "@webbuf/sha256": "^3.5.0",
    "@webbuf/webbuf": "^3.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "feed": "^5.2.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "mysql2": "^3.22.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "toml": "^4.1.1",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@webgpu/types": "^0.1.68",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
