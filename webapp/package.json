{
  "name": "@keypears/webapp",
  "type": "module",
  "scripts": {
    "dev:keypears": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.dev -- vite --port 3500",
    "dev:passapples": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f .env.dev.passapples -- vite --port 3512",
    "build": "vite build",
    "start": "bun dist/server/server.js",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "bun run db:push:keypears && bun run db:push:passapples",
    "db:push:keypears": "dotenvx run -f .env.dev -- drizzle-kit push",
    "db:push:passapples": "dotenvx run -f .env.dev.passapples -- drizzle-kit push",
    "db:clear": "bun run db:clear:keypears && bun run db:clear:passapples",
    "db:clear:keypears": "dotenvx run -f .env.dev -- drizzle-kit push --config drizzle.clear.config.ts",
    "db:clear:passapples": "dotenvx run -f .env.dev.passapples -- drizzle-kit push --config drizzle.clear.config.ts",
    "db:generate": "dotenvx run -f .env.dev -- drizzle-kit generate",
    "build:icons": "bun run process-icons.ts",
    "test": "dotenvx run -f .env.test -- vitest run"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@keypears/pow5": "workspace:*",
    "@orpc/client": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-start": "^1.167.16",
    "@webbuf/acs2": "^3.5.0",
    "@webbuf/blake3": "^3.5.0",
    "@webbuf/fixedbuf": "^3.5.0",
    "@webbuf/secp256k1": "^3.5.0",
    "@webbuf/sha256": "^3.5.0",
    "@webbuf/webbuf": "^3.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "mysql2": "^3.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
