---
import { getEntry, render } from "astro:content";
import DocPage from "../../layouts/DocPage.astro";
import { getPrevNext } from "../../lib/nav";

const slug = "protocol/proof-of-work";
const entry = await getEntry("docs", slug);
if (!entry) throw new Error(`${slug} not found`);
const { Content } = await render(entry);
const { prev, next } = getPrevNext(slug);
---

<DocPage title={entry.data.title} description={entry.data.description} prev={prev} next={next}>
  <Content />
</DocPage>
