---
import { getEntry, render } from "astro:content";
import DocPage from "../layouts/DocPage.astro";
import { getPrevNext } from "../lib/nav";

const entry = await getEntry("docs", "index");
if (!entry) throw new Error("index not found");
const { Content } = await render(entry);
const { prev, next } = getPrevNext("index");
---

<DocPage title={entry.data.title} description={entry.data.description} prev={prev} next={next}>
  <Content />
</DocPage>
