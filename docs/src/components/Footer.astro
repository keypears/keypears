---
import type { Props } from "@astrojs/starlight/props";

const { prev, next } = Astro.locals.starlightRoute.pagination;
---

<footer class="kp-footer not-content">
  <nav class="kp-page-nav">
    {prev ? (
      <a href={prev.href} class="kp-nav-link">
        <span class="kp-arrow">&larr;</span>
        <span>{prev.label}</span>
      </a>
    ) : <span />}
    {next ? (
      <a href={next.href} class="kp-nav-link">
        <span>{next.label}</span>
        <span class="kp-arrow">&rarr;</span>
      </a>
    ) : <span />}
  </nav>

  <div class="kp-brand">
    <a href="https://astrohacker.com" class="kp-brand-link">
      <picture>
        <source
          srcset="/images/astrohacker-6-dark-32.webp"
          media="(prefers-color-scheme: dark)"
        />
        <img
          src="/images/astrohacker-6-light-32.webp"
          alt="Astrohacker logo"
          width="20"
          height="20"
        />
      </picture>
      <span>An Astrohacker Project</span>
    </a>
  </div>
</footer>
