#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/ryan/dev/keypears/node_modules/.pnpm/png-to-ico@3.0.1/node_modules/png-to-ico/bin/node_modules:/Users/ryan/dev/keypears/node_modules/.pnpm/png-to-ico@3.0.1/node_modules/png-to-ico/node_modules:/Users/ryan/dev/keypears/node_modules/.pnpm/png-to-ico@3.0.1/node_modules:/Users/ryan/dev/keypears/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/ryan/dev/keypears/node_modules/.pnpm/png-to-ico@3.0.1/node_modules/png-to-ico/bin/node_modules:/Users/ryan/dev/keypears/node_modules/.pnpm/png-to-ico@3.0.1/node_modules/png-to-ico/node_modules:/Users/ryan/dev/keypears/node_modules/.pnpm/png-to-ico@3.0.1/node_modules:/Users/ryan/dev/keypears/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../png-to-ico/bin/cli.js" "$@"
else
  exec node  "$basedir/../png-to-ico/bin/cli.js" "$@"
fi
